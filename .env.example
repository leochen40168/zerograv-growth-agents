# OpenAI API 金鑰，用於產生內容草稿，可不填
OPENAI_API_KEY=

# OpenAI 模型名稱；只有啟用內容草稿產生時才會使用
OPENAI_MODEL=gpt-4.1-mini

# WordPress 網站網址；未來選配功能，目前不是主流程
WORDPRESS_URL=

# WordPress 使用者名稱；未來選配功能，目前可留空
WORDPRESS_USERNAME=

# WordPress Application Password；未來選配功能，目前可留空
WORDPRESS_APP_PASSWORD=

# SMTP 主機，用於寄送廠商開發信；寄信功能預設關閉
EMAIL_SMTP_HOST=

# SMTP 連接埠，常見值為 587
EMAIL_SMTP_PORT=587

# SMTP 帳號
EMAIL_SMTP_USERNAME=

# SMTP 密碼，請只放在本機 .env，不要提交到 GitHub
EMAIL_SMTP_PASSWORD=

# 寄件者顯示名稱
EMAIL_FROM_NAME=ZeroGrav

# 寄件者 Email 地址
EMAIL_FROM_ADDRESS=

# 每日寄信上限，建議維持 10 到 20 封
EMAIL_DAILY_LIMIT=20

# 是否啟用自動寄信，預設 false，建議先不要開啟
EMAIL_SEND_ENABLED=false
